<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <com.tw.eq.widget.ZoneView
            android:id="@+id/zone_view"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/zone_left"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_left"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/balance"
                android:textColor="@color/text_primary"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/zone_right"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_right"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/zone_up"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fader"
                android:textColor="@color/text_primary"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/zone_down"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_down"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <Button
            android:id="@+id/zone_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset_center"
            android:layout_marginTop="10dp"
            android:background="@drawable/button_bg" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subwoofer_settings"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:gravity="center" />

        <com.tw.eq.widget.DounbleThumbSeekbar
            android:id="@+id/sub_freq_seek"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/sub_freq_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASS"
            android:textColor="@color/eq_progress"
            android:layout_marginTop="5dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/spdif"
                android:textColor="@color/text_primary" />

            <com.tw.eq.widget.EqScaleView
                android:id="@+id/spdif_seek"
                android:layout_width="60dp"
                android:layout_height="150dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/center"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.tw.eq.widget.EqScaleView
                android:id="@+id/center_seek"
                android:layout_width="60dp"
                android:layout_height="150dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sub_gain"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.tw.eq.widget.EqScaleView
                android:id="@+id/sub_gain_seek"
                android:layout_width="60dp"
                android:layout_height="150dp" />

        </LinearLayout>

        <Button
            android:id="@+id/sub_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset_sub"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_bg" />

    </LinearLayout>

</ScrollView>
