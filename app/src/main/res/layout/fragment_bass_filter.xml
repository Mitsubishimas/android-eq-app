<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <ImageView
            android:id="@+id/filter_car"
            android:layout_width="200dp"
            android:layout_height="150dp"
            android:src="@drawable/ic_car_icon" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/filter_front_mute"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_mute" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/front"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginLeft="8dp" />

                    <ImageView
                        android:id="@+id/front_voice"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_voice"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/front_filter_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASS"
                    android:textColor="@color/eq_progress"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <SeekBar
                    android:id="@+id/front_filter_seek"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:max="11"
                    android:progress="0" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/filter_rear_mute"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_mute" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rear"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginLeft="8dp" />

                    <ImageView
                        android:id="@+id/rear_voice"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_voice"
                        android:layout_marginLeft="8dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/rear_filter_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASS"
                    android:textColor="@color/eq_progress"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <SeekBar
                    android:id="@+id/rear_filter_seek"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:max="11"
                    android:progress="0" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/filter_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reset"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_bg" />

    </LinearLayout>

</ScrollView>
