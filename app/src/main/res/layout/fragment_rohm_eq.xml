<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/eq_mode_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/eq_modes"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/eq_modes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/mode_custom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_custom"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_classic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_classic"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_rock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_rock"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_jazz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_jazz"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_pop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_pop"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_dance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_dance"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />

            <RadioButton
                android:id="@+id/mode_vocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_vocal"
                android:button="@null"
                android:background="@drawable/eq_mode_selector"
                android:padding="8dp"
                android:textColor="@drawable/eq_mode_text_selector" />
        </RadioGroup>

        <ImageView
            android:id="@+id/eq_level_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_page_indicator"
            android:padding="4dp" />
    </LinearLayout>

    <com.tw.eq.widget.Workspace
        android:id="@+id/eq_workspace"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/eq_group_1"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/eq_group_2"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/eq_group_3"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />

        </LinearLayout>

    </com.tw.eq.widget.Workspace>

    <com.tw.eq.widget.LineGraphicView
        android:id="@+id/eq_curve"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_margin="8dp"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/eq_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp">

        <ImageView
            android:id="@+id/eq_nav_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_nav_dot"
            android:padding="4dp" />

        <ImageView
            android:id="@+id/eq_nav_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_nav_dot"
            android:padding="4dp" />

        <ImageView
            android:id="@+id/eq_nav_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_nav_dot"
            android:padding="4dp" />

    </LinearLayout>

</LinearLayout>
