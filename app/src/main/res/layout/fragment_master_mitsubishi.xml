<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eq_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Выбор режима -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/master_mitsubishi"
            android:textColor="@color/eq_progress"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/eq_mode"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/mode_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Выбор предустановки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/preset"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/preset_spinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

        <!-- Заголовок частот -->
        <TextView
            android:id="@+id/title_frequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eq_5band"
            android:textColor="@color/eq_progress"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 5-полосный эквалайзер -->
        <LinearLayout
            android:id="@+id/layout_5band"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- 63 Hz -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/freq_63hz"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_63hz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_63hz"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- 330 Hz -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/freq_330hz"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_330hz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_330hz"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- 2000 Hz -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/freq_2000hz"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_2000hz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_2000hz"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- 6300 Hz -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/freq_6300hz"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_6300hz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_6300hz"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- 15000 Hz -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/freq_15000hz"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_15000hz"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_15000hz"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- 3-полосный эквалайзер (Bass, Mid, Treble) -->
        <LinearLayout
            android:id="@+id/layout_3band"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Bass -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/bass"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_bass"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_bass"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Mid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/mid"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_mid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_mid"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Treble -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/treble"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <SeekBar
                    android:id="@+id/seek_treble"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="24"
                    android:progress="12" />

                <TextView
                    android:id="@+id/value_treble"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="0 dB"
                    android:textColor="@color/eq_progress"
                    android:textSize="12sp"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Кнопка сброса -->
        <Button
            android:id="@+id/reset_eq"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="@string/reset"
            android:background="@drawable/button_bg"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

</ScrollView>
